{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://affable-gentle-care-path.base44.app/api/:path*"
    },
    {
      "source": "/app-logs/:path*",
      "destination": "https://affable-gentle-care-path.base44.app/app-logs/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
